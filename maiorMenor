package estudo;

import java.util.Scanner;

public class prova1 {
    public static void main(String[] args) {
        int num1 = 0;
        int contador =0;
        int menor = 0;
        for(int i =1;;i++){
            Scanner sc = new Scanner(System.in);
            System.out.println("Digite um número: ");
            int num = sc.nextInt();
            if(i==1){
                menor=num;
            }
            if(num<menor && num>0 ){
                menor=num;
            }
            if(contador<num){
                contador=num;
            }
            num1+=num;
            if(num>=0){
                System.out.println(num1/i);
            }
            if(num<0){
                break;
            }
        }
        System.out.println("menor valor: "+ menor);
        System.out.println("maior valor: "+ contador    );
    }
}
